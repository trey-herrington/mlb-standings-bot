# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# balldontlie API key from https://app.balldontlie.io
BALLDONTLIE_API_KEY=your_api_key_here

# Discord channel ID where standings will be posted daily
# Right-click a channel in Discord (with Developer Mode on) -> Copy Channel ID
CHANNEL_ID=123456789012345678

# Cron schedule for daily posting (default: 10:00 AM ET / 3:00 PM UTC)
# Format: sec min hour day_of_month month day_of_week
CRON_SCHEDULE=0 0 15 * * *

# Optional: Override the MLB season year (e.g., 2025)
# If not set, the bot auto-detects based on the current date
# MLB_SEASON=2025
